<!-- Merge into ios/Runner/Info.plist between the existing <dict> tags. -->

<key>NSPhotoLibraryUsageDescription</key>
<string>Picture Book needs access to your photo library so teachers can choose images for new book pages.</string>

<!-- Defense in depth: even though we make no calls, deny arbitrary loads. -->
<key>NSAppTransportSecurity</key>
<dict>
  <key>NSAllowsArbitraryLoads</key>
  <false/>
</dict>

<!-- iPad supports landscape and portrait; tablets are forced to landscape via SystemChrome at runtime. -->
<key>UISupportedInterfaceOrientations~ipad</key>
<array>
  <string>UIInterfaceOrientationLandscapeLeft</string>
  <string>UIInterfaceOrientationLandscapeRight</string>
  <string>UIInterfaceOrientationPortrait</string>
  <string>UIInterfaceOrientationPortraitUpsideDown</string>
</array>
